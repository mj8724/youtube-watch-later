{
  "manifest_version": 3,
  "name": "YouTube 批量稍后观看",
  "version": "1.0.6",
  "description": "在 YouTube 频道页面批量添加视频到稍后观看列表",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
